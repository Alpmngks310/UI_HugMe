<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollHome"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/awan2"
    android:overScrollMode="always"
    android:scrollbars="vertical"
    tools:context=".HomeActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/txtGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hi, Username 👋"
                android:textColor="#455A64"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/txtSubGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="How are you feeling today?"
                android:textColor="#607D8B"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular" />
        </LinearLayout>

        <!-- MOOD CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_hugme"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Mood"
                android:textColor="#455A64"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tap to record your mood"
                android:textColor="#607D8B"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="😄"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="😌"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="😢"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="😣"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="😰"
                    android:textSize="28sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- PANIC CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_hugme"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feeling overwhelmed?"
                android:textColor="#455A64"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Tap the button below to start a quick calming activity."
                android:textColor="#607D8B"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="10dp">

                <Button
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:backgroundTint="#F4B4C8"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="I'M FEELING PANIC"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:stateListAnimator="@null" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- QUICK RELIEF -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Relief"
            android:textColor="#455A64"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/poppins_bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/cardBreathing"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_input_hugme"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🫁"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Breathing\nExercise"
                        android:textAlignment="center"
                        android:textColor="#455A64"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardFocus"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_input_hugme"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Focus\nGame"
                        android:textAlignment="center"
                        android:textColor="#455A64"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardGrounding"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="@drawable/bg_input_hugme"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Grounding 5-4-3-2-1"
                    android:textColor="#455A64"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Come back to the present moment"
                    android:textColor="#607D8B"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>
        </LinearLayout>

        <!-- STATS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_hugme"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mood Stats"
                android:textColor="#455A64"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Your mood trend this week"
                android:textColor="#607D8B"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="16dp"
                android:gravity="bottom|center"
                android:orientation="horizontal">

                <View
                    android:layout_width="24dp"
                    android:layout_height="55dp"
                    android:layout_margin="6dp"
                    android:background="#F8C8D8" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="80dp"
                    android:layout_margin="6dp"
                    android:background="#F4B4C8" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="45dp"
                    android:layout_margin="6dp"
                    android:background="#F8C8D8" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="95dp"
                    android:layout_margin="6dp"
                    android:background="#F4B4C8" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="70dp"
                    android:layout_margin="6dp"
                    android:background="#F8C8D8" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="100dp"
                    android:layout_margin="6dp"
                    android:background="#F4B4C8" />

                <View
                    android:layout_width="24dp"
                    android:layout_height="60dp"
                    android:layout_margin="6dp"
                    android:background="#F8C8D8" />
            </LinearLayout>
        </LinearLayout>

        <!-- RECOMMENDATION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_hugme"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Recommendation"
                android:textColor="#455A64"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/txtRecommendation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Take a deep breath. You’re doing okay. Try a 2-minute meditation or write down what you’re feeling today."
                android:textColor="#607D8B"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="@font/poppins_regular" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>