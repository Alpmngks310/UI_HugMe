<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WelcomeActivity">

    <!-- BACKGROUND IMAGE -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/awan"
        android:scaleType="centerCrop"
        android:alpha="0.5" /> <!-- buat samar -->

    <!-- OPTIONAL OVERLAY supaya teks lebih jelas -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80FFFFFF" /> <!-- putih 50% opacity -->

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:id="@+id/scrollViewWelcome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="32dp">

            <!-- BACKGROUND ILLUSTRATION -->
            <FrameLayout
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="250dp"
                    android:layout_height="250dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="125dp"
                    app:cardElevation="0dp"
                    android:layout_gravity="center">

                    <ImageView
                        android:id="@+id/imgBackground"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/hugmeee" />

                </androidx.cardview.widget.CardView>

            </FrameLayout>

            <!-- TITLE -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Find Your Inner Peace"
                android:textSize="28sp"
                android:textColor="#2E4D3E"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <!-- SUBTITLE -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Take a moment to breathe and relax."
                android:textSize="14sp"
                android:textColor="#607D8B"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <!-- GET STARTED BUTTON -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnGetStarted"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:backgroundTint="#F4B4C8"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="GET STARTED"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:stateListAnimator="@null" />

            </androidx.cardview.widget.CardView>

            <!-- LOGIN LINK -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textColor="#455A64"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/tvLoginLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log in"
                    android:textColor="#ffb8c6"
                    android:textStyle="italic"
                    android:fontFamily="@font/poppins_bold" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>