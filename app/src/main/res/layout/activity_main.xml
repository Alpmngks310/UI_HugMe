<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:overScrollMode="never"
    android:scaleType="centerCrop"
    android:descendantFocusability="beforeDescendants">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="top|center_horizontal"
        android:padding="20dp"
        android:background="@drawable/awan1">

        <!-- LOGO -->
        <FrameLayout
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/glow_background">

            <androidx.cardview.widget.CardView
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="80dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/hugmeee" />

            </androidx.cardview.widget.CardView>

        </FrameLayout>


        <!-- CONTAINER PUTIH -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/bg_input_hugme">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center"
                android:text="Hello Dear!"
                android:textColor="#455A64"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:text="Your safe space for mental wellness"
                android:textColor="#607D8B"
                android:textSize="14sp" />


            <!-- EMAIL -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Email Address"
                android:textColorHint="#546E7A"
                app:hintTextColor="#000000"
                app:boxCornerRadiusTopStart="30dp"
                app:boxCornerRadiusTopEnd="30dp"
                app:boxCornerRadiusBottomStart="30dp"
                app:boxCornerRadiusBottomEnd="30dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="#F4B4C8"
                app:startIconDrawable="@android:drawable/ic_dialog_email"
                app:startIconTint="#546E7A">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:paddingStart="50dp"
                    android:textColor="#000000" />

            </com.google.android.material.textfield.TextInputLayout>


            <!-- PASSWORD -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:hint="Password"
                android:textColorHint="#546E7A"
                app:hintTextColor="#000000"
                app:boxCornerRadiusTopStart="30dp"
                app:boxCornerRadiusTopEnd="30dp"
                app:boxCornerRadiusBottomStart="30dp"
                app:boxCornerRadiusBottomEnd="30dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="#F4B4C8"
                app:endIconMode="password_toggle"
                app:endIconTint="#F4B4C8"                app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                app:startIconTint="#546E7A">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:paddingStart="50dp"
                    android:textColor="#000000" />

            </com.google.android.material.textfield.TextInputLayout>


            <!-- LOGIN BUTTON -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="12dp">

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:backgroundTint="#F4B4C8"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="LOGIN"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:stateListAnimator="@null" />

            </androidx.cardview.widget.CardView>


            <!-- SIGN UP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account? "
                    android:textColor="#455A64" />

                <TextView
                    android:id="@+id/edtConfirmPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Up"
                    android:textStyle="bold"
                    android:textColor="#F4B4C8" />

            </LinearLayout>


            <!-- FORGOT PASSWORD -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="Forgot Password?"
                android:textColor="#546E7A"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>