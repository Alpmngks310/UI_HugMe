    <!-- Tema Splash Screen -->
    <style name="Theme.MyApplication.Splash" parent="Theme.MyApplication">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

</resources>